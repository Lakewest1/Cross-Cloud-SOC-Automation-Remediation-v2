{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "DynamoDB table for Sentinel remediation idempotency - Cross-Cloud SOC Auto-Remediation System",
  
  "Parameters": {
    "TableName": {
      "Type": "String",
      "Default": "sentinel-remediation-log",
      "Description": "Name of the DynamoDB table",
      "MinLength": 3,
      "MaxLength": 255
    },
    "BillingMode": {
      "Type": "String",
      "Default": "PAY_PER_REQUEST",
      "AllowedValues": ["PROVISIONED", "PAY_PER_REQUEST"],
      "Description": "Billing mode for DynamoDB table"
    },
    "ReadCapacityUnits": {
      "Type": "Number",
      "Default": 5,
      "Description": "Read capacity units for PROVISIONED mode",
      "Condition": "IsProvisioned"
    },
    "WriteCapacityUnits": {
      "Type": "Number",
      "Default": 5,
      "Description": "Write capacity units for PROVISIONED mode",
      "Condition": "IsProvisioned"
    },
    "TTLInDays": {
      "Type": "Number",
      "Default": 90,
      "Description": "Time-to-live in days for records",
      "MinValue": 1,
      "MaxValue": 365
    }
  },
  
  "Conditions": {
    "IsProvisioned": {
      "Fn::Equals": [{"Ref": "BillingMode"}, "PROVISIONED"]
    }
  },
  
  "Resources": {
    "RemediationLogTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": {"Ref": "TableName"},
        "AttributeDefinitions": [
          {
            "AttributeName": "incident_id",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "incident_id",
            "KeyType": "HASH"
          }
        ],
        "BillingMode": {"Ref": "BillingMode"},
        "ProvisionedThroughput": {
          "Fn::If": [
            "IsProvisioned",
            {
              "ReadCapacityUnits": {"Ref": "ReadCapacityUnits"},
              "WriteCapacityUnits": {"Ref": "WriteCapacityUnits"}
            },
            {"Ref": "AWS::NoValue"}
          ]
        },
        "TimeToLiveSpecification": {
          "AttributeName": "ttl",
          "Enabled": true
        },
        "PointInTimeRecoverySpecification": {
          "PointInTimeRecoveryEnabled": true
        },
        "SSESpecification": {
          "SSEEnabled": true,
          "SSEType": "KMS"
        },
        "Tags": [
          {
            "Key": "Project",
            "Value": "Cross-Cloud-SOC-Auto-Remediation"
          },
          {
            "Key": "Environment",
            "Value": "Production"
          },
          {
            "Key": "ManagedBy",
            "Value": "Sentinel"
          },
          {
            "Key": "CostCenter",
            "Value": "Security-Automation"
          }
        ]
      }
    }
  },
  
  "Outputs": {
    "TableName": {
      "Description": "Name of the DynamoDB table",
      "Value": {"Ref": "RemediationLogTable"}
    },
    "TableArn": {
      "Description": "ARN of the DynamoDB table",
      "Value": {"Fn::GetAtt": ["RemediationLogTable", "Arn"]}
    }
  }
}